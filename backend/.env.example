# Draurls 后端服务配置文件示例
# 复制此文件为 .env 并修改相应的配置值

# ====================
# 服务器配置
# ====================
SERVER_PORT=8080
SERVER_MODE=debug          # debug, release, test
SERVER_BASE_URL=           # 留空自动适配前端访问地址

# ====================
# 数据库配置 (MySQL)
# ====================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=draurls
DB_CHARSET=utf8mb4
DB_PARSE_TIME=true
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_CONN_MAX_LIFETIME=300   # 秒

# ====================
# Redis 配置
# ====================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=           # 留空表示无密码
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=5

# ====================
# Keycloak OIDC 配置
# ====================
# Keycloak 服务器地址
KEYCLOAK_BASE_URL=http://localhost:8081
# Realm 名称
KEYCLOAK_REALM=draurls
# 客户端 ID
KEYCLOAK_CLIENT_ID=draurls
# 客户端密钥（如果需要）
KEYCLOAK_SECRET=
# 回调地址（后端回调地址）
KEYCLOAK_CALLBACK_URL=http://localhost:8080/api/auth/callback

# ====================
# 安全配置
# ====================
# JWT 签名密钥 (生产环境请使用强随机密钥)
JWT_SECRET=your-jwt-secret-change-in-production
ENABLE_HTTPS=false

# ====================
# 缓存配置
# ====================
# 缓存 TTL (秒)
CACHE_HOT_TTL=3600            # 热数据: 1小时
CACHE_WARM_TTL=86400           # 温数据: 24小时
CACHE_COLD_TTL=604800          # 冷数据: 7天

# ====================
# 限流配置
# ====================
# 限流配置 (请求数/时间窗口)
RATE_LIMIT_IP=100             # IP 限流: 100次/分钟
RATE_LIMIT_USER=200           # 用户限流: 200次/分钟
RATE_LIMIT_API=500            # API密钥限流: 500次/分钟
RATE_LIMIT_GLOBAL=10000       # 全局限流: 10000次/秒

# ====================
# Worker 配置
# ====================
# Worker 并发数
WORKER_POOL_SIZE=100
WORKER_TASK_QUEUE_SIZE=1000
