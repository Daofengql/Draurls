# Surls 后端服务配置文件示例
# 复制此文件为 .env 并修改相应的配置值

# ====================
# 服务器配置
# ====================
SERVER_PORT=8080
SERVER_MODE=debug          # debug, release, test
SERVER_BASE_URL=           # 短链基础域名，留空则使用 http://localhost:8080

# ====================
# 数据库配置 (MySQL)
# ====================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=surls

# ====================
# Redis 配置
# ====================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=           # 留空表示无密码
REDIS_DB=0

# ====================
# Keycloak 配置 (暂未完全集成，当前使用 Mock 认证)
# ====================
KEYCLOAK_BASE_URL=http://localhost:8081
KEYCLOAK_REALM=surls
KEYCLOAK_CLIENT_ID=surls
KEYCLOAK_SECRET=
KEYCLOAK_CALLBACK_URL=http://localhost:3000/callback

# ====================
# 安全配置
# ====================
JWT_SECRET=your-jwt-secret-change-in-production
ENABLE_HTTPS=false

# ====================
# 测试 Token (仅用于 Mock 认证模式)
# ====================
# 使用 Authorization: Bearer admin-token 作为管理员
# 使用 Authorization: Bearer user-token 作为普通用户
