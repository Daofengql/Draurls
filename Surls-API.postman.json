	"item": [
		{
			"name": "健康检查",
			"item": [
				{
					"name": "基础健康检查",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/health",
							"host": ["{{baseUrl}}"],
							"path": ["health"]
						},
						"description": "检查服务器是否正常运行"
					}
				},
				{
					"name": "就绪检查 (含依赖服务状态)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/readiness",
							"host": ["{{baseUrl}}"],
							"path": ["readiness"]
