	{
		"name": "API签名认证接口",
		"item": [
			{
				"name": "创建短链接（签名认证）",
				"request": {
					"method": "POST",
					"header": [
						{
							"key": "Content-Type",
							"value": "application/json"
						},
						{
							"key": "X-API-Key",
							"value": "{{apiKey}}",
							"description": "API密钥"
						},
						{
							"key": "X-Signature",
							"value": "{{signature}}",
							"description": "HMAC-SHA256签名"
						},
						{
							"key": "X-Timestamp",
							"value": "{{timestamp}}",
							"description": "当前时间戳（秒）"
						},
						{
							"key": "X-Nonce",
							"value": "{{nonce}}",
							"description": "随机字符串"
						}
					],
					"body": {
						"mode": "raw",
						"raw": "{\n    \"url\": \"https://www.example.com\",\n    \"title\": \"通过API创建的短链接\"\n}"
					},
					"url": {
						"raw": "{{baseUrl}}/api/v1/shorten",
						"host": ["{{baseUrl}}"],
						"path": ["api", "v1", "shorten"]
					},
					"description": "使用API签名认证创建短链接，供第三方应用调用。\n\n签名计算方式：\nHMAC-SHA256(apiKeySecret, timestamp + nonce + requestBody + \"/api/v1/shorten\" + \"POST\")"
				}
			}
		],
		"description": "使用API签名认证的外部调用接口"
	},
