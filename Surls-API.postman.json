{
	"info": {
		"_postman_id": "surls-api-collection",
		"name": "Surls 短链接服务 API",
		"description": "Surls 短链接服务的完整 API 测试集合，包含健康检查、用户管理、短链接管理、API密钥管理和管理员功能��",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "健康检查",
			"item": [
				{
					"name": "基础健康检查",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/health",
							"host": ["{{baseUrl}}"],
							"path": ["health"]
						},
						"description": "检查服务器是否正常运行"
					}
				},
				{
					"name": "就绪检查 (含依赖服务状态)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/readiness",
							"host": ["{{baseUrl}}"],
							"path": ["readiness"]
						},
						"description": "检查服务器及依赖服务（数据库、Redis）状态"
					}
				},
				{
					"name": "存活检查 (Kubernetes)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/liveness",
							"host": ["{{baseUrl}}"],
							"path": ["liveness"]
						},
						"description": "Kubernetes 存活探针使用"
					}
				}
			],
			"description": "服务器健康状态检查接口"
		},
		{
			"name": "公开API",
			"item": [
				{
					"name": "获取站点配置",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/config",
							"host": ["{{baseUrl}}"],
							"path": ["api", "config"]
						},
						"description": "获取公开的站点配置信息（站点名称、Logo等）"
					}
				}
			],
			"description": "无需认证的公开接口"
		},
		{
			"name": "用户相关",
			"item": [
				{
					"name": "获取当前用户资料",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{adminToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/user/profile",
							"host": ["{{baseUrl}}"],
							"path": ["api", "user", "profile"]
						},
						"description": "获取当前登录用户的个人信息"
					}
				},
				{
					"name": "获取用户配额状态",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{userToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/user/quota",
							"host": ["{{baseUrl}}"],
							"path": ["api", "user", "quota"]
